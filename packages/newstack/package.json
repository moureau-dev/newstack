{
  "name": "newstack",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "bin": {
    "newstack": "./bin/newstack.js"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./builder": "./src/builder.ts",
    "./esbuild": "./src/esbuild.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "exports": {
      ".": "./dist/index.js",
      "./server": "./dist/server.js",
      "./builder": "./dist/builder.js",
      "./esbuild": "./dist/esbuild.js"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts src/server.ts src/builder.ts src/esbuild.ts --bundle --platform=node --format=esm --external:esbuild --external:@swc/core --outdir=dist --minify",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@newstack/framework": "workspace:^",
    "@newstack/builder": "workspace:^",
    "@newstack/jsx": "workspace:^",
    "esbuild": "^0.25.5",
    "@swc/core": "^1.15.2"
  }
}
